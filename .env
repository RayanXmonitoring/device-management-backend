# Server Configuration
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/device_management?retryWrites=true&w=majority

# Redis Configuration
REDIS_URL=redis://default:sfiRuzinJVUiqxSenYlfLApqdhQvqZcj@redis.railway.internal:6379
REDIS_PASSWORD=sfiRuzinJVUiqxSenYlfLApqdhQvqZcj

# Firebase Configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@project.iam.gserviceaccount.com

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRATION=7d
REFRESH_TOKEN_EXPIRATION=30d

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=https://your-frontend.railway.app,http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# Feature Flags
ENABLE_SOCKET_IO=true
ENABLE_SWAGGER=true
ENABLE_AUDIT_LOG=true
ENABLE_DEVICE_SYNC=true

# Security
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
